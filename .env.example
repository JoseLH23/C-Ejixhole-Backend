# Copia este archivo a .env y ajusta los valores reales.
# .env NUNCA debe subirse a git (agrégalo a .gitignore).

DATABASE_URL=postgresql+psycopg2://ejixhole_user:changeme@localhost:5432/ejixhole_db
JWT_SECRET_KEY=genera-una-clave-larga-y-aleatoria-aqui
JWT_EXPIRE_MINUTES=60

# Credencial separada para la integración MH-Core de solo lectura.
# Debe ser distinta a JWT_SECRET_KEY y MH_CORE_API_KEY.
# Genera una real con: python -c "import secrets; print(secrets.token_urlsafe(48))"
MH_CORE_SERVICE_KEY=

# Publicación confiable de eventos EjiXhole -> MH-Core.
# URL completa del webhook, por ejemplo:
# https://mh-core.example.com/integrations/ejixhole/events
MH_CORE_EVENTS_URL=
# Debe coincidir con EJIXHOLE_EVENT_SIGNING_SECRET en MH-Core y ser distinta
# de todas las demás claves.
MH_CORE_EVENT_SIGNING_SECRET=
OUTBOX_BATCH_SIZE=10
OUTBOX_MAX_ATTEMPTS=8
OUTBOX_LEASE_SECONDS=120
OUTBOX_INITIAL_BACKOFF_SECONDS=10
OUTBOX_MAX_BACKOFF_SECONDS=3600
OUTBOX_REQUEST_TIMEOUT_SECONDS=10
OUTBOX_POLL_INTERVAL_SECONDS=10

# Opcional — si se deja vacío, el sistema sigue funcionando sin enviar
# correos de aviso (la reservación se crea y se ve en el Dashboard igual).
# Para Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, y SMTP_PASSWORD
# debe ser una "contraseña de aplicación" (no tu contraseña normal).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFICACIONES_EMAIL_DESTINO=
